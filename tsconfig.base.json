{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "easymatrix": ["packages/core/src/index.ts"],
      "@beeper/easymatrix-ai-sdk": ["packages/ai-sdk/src/index.ts"],
      "@beeper/easymatrix-chat-adapter": ["packages/chat-adapter/src/index.ts"],
      "@beeper/easymatrix-cloudflare": ["packages/cloudflare/src/index.ts"],
      "@beeper/easymatrix-state-file": ["packages/state-file/src/index.ts"],
      "@beeper/easymatrix-state-indexeddb": ["packages/state-indexeddb/src/index.ts"],
      "@beeper/easymatrix-state-memory": ["packages/state-memory/src/index.ts"],
      "@beeper/easymatrix-state-simple": ["packages/state-simple/src/index.ts"],
      "@beeper/easymatrix-state-sqlite": ["packages/state-sqlite/src/index.ts"],
      "easymatrix/node": ["packages/core/src/node.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "useDefineForClassFields": true
  }
}
