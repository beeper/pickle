MATRIX_HOMESERVER=https://matrix.example
MATRIX_ACCESS_TOKEN=syt_your_appservice_or_bot_token
MATRIX_SERVER_NAME=example

# Optional: use Beeper bridge-manager-compatible APIs to fetch/register the appservice.
# BEEPER_ACCESS_TOKEN=your_beeper_access_token
# BEEPER_BASE_DOMAIN=beeper.com

# Local registration fallback when BEEPER_ACCESS_TOKEN is not set.
DUMMYBRIDGE_AS_ID=dummybridge
DUMMYBRIDGE_AS_TOKEN=generate-a-long-random-token
DUMMYBRIDGE_HS_TOKEN=generate-another-long-random-token
DUMMYBRIDGE_SENDER_LOCALPART=dummybridgebot

# Optional live actions after startup.
# DUMMYBRIDGE_CREATE_ROOM=1
# DUMMYBRIDGE_PORTAL_ROOM_ID=!existing:example
# DUMMYBRIDGE_BACKFILL_ON_START=1
