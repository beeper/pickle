{
  "name": "@beeper/pickle-ag-ui",
  "version": "0.1.0",
  "description": "AG-UI stream adapters for Pickle",
  "type": "module",
  "homepage": "https://github.com/beeper/pickle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeper/pickle.git",
    "directory": "packages/ag-ui"
  },
  "bugs": {
    "url": "https://github.com/beeper/pickle/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "prepublishOnly": "node ../../scripts/guard-pnpm-publish.mjs",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "matrix",
    "ag-ui",
    "streaming",
    "beeper"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@ag-ui/core": "0.0.52",
    "@tanstack/ai": "0.18.0",
    "@tanstack/ai-client": "0.10.0"
  }
}
