{
  "name": "@beeper/easymatrix-cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare Workers and Durable Objects helpers for EasyMatrix",
  "type": "module",
  "homepage": "https://github.com/beeper/EasyMatrix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeper/EasyMatrix.git",
    "directory": "packages/cloudflare"
  },
  "bugs": {
    "url": "https://github.com/beeper/EasyMatrix/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "node ../../scripts/guard-pnpm-publish.mjs",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "easymatrix": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "matrix",
    "cloudflare",
    "workers",
    "durable-objects"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0"
}
