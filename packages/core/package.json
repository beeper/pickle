{
  "name": "better-matrix-js",
  "version": "0.1.0",
  "description": "WASM-backed TypeScript Matrix SDK built on mautrix-go",
  "type": "module",
  "homepage": "https://github.com/batuhan/better-matrix-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/batuhan/better-matrix-js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/batuhan/better-matrix-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./matrix-core.wasm": "./dist/matrix-core.wasm",
    "./wasm_exec.js": "./dist/wasm_exec.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && npm run build:wasm",
    "build:wasm": "mkdir -p dist && cd native && GOOS=js GOARCH=wasm CGO_ENABLED=0 go build -tags goolm -ldflags='-s -w' -o ../dist/matrix-core.wasm ./cmd/matrix-wasm && cp \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" ../dist/wasm_exec.js",
    "clean": "rm -rf dist",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "matrix",
    "mautrix",
    "wasm",
    "e2ee",
    "olm",
    "chat-sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0"
}
