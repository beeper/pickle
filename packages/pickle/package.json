{
  "name": "@beeper/pickle",
  "version": "0.1.0",
  "description": "WASM-backed TypeScript Matrix SDK built on mautrix-go",
  "type": "module",
  "homepage": "https://github.com/beeper/pickle#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeper/pickle.git",
    "directory": "packages/pickle"
  },
  "bugs": {
    "url": "https://github.com/beeper/pickle/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./beeper/auth": {
      "types": "./dist/beeper/auth.d.ts",
      "import": "./dist/beeper/auth.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./pickle.wasm": "./dist/pickle.wasm",
    "./wasm_exec.js": "./dist/wasm_exec.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run generate:types && tsdown && npm run build:wasm",
    "build:wasm": "mkdir -p dist && cd native && GOOS=js GOARCH=wasm CGO_ENABLED=0 go build -tags goolm -ldflags='-s -w' -o ../dist/pickle.wasm ./cmd/matrix-wasm && cp \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" ../dist/wasm_exec.js",
    "clean": "rm -rf dist",
    "generate:types": "cd native && go run ./cmd/matrix-ts-types",
    "test": "vitest run --coverage",
    "typecheck": "npm run generate:types && tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "matrix",
    "mautrix",
    "wasm",
    "e2ee",
    "olm",
    "chat-sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0"
}
