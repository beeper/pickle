{
  "name": "@beeper/pickle-dummybot",
  "version": "0.1.0",
  "description": "Dummy Matrix bridge bot for Pickle stream testing",
  "type": "module",
  "bin": {
    "dummybot": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "node ../../scripts/guard-pnpm-publish.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@beeper/pickle": "workspace:*",
    "@beeper/pickle-state-file": "workspace:*",
    "dotenv": "^17.2.3",
    "nanoid": "^5.1.6",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/seedrandom": "^3.0.8",
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "keywords": ["matrix", "pickle", "dummybot", "bridge", "streaming"],
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0"
}
